generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  orderIndex  Int       @default(0)
  devices     Device[]
}

model Device {
  id              Int       @id @default(autoincrement())
  name            String
  categoryId      Int
  category        Category  @relation(fields: [categoryId], references: [id])
  defaultWatts    Float
  defaultHoursDay Float
  icon            String    @default("fa-plug")
  description     String?
  unitType        String    @default("Watts")
  isActive        Boolean   @default(true)
  orderIndex      Int       @default(0)
}

model Product {
  id            Int       @id @default(autoincrement())
  type          String    // Ejemplo: 'panel', 'battery', 'inverter'
  name          String
  capacity      Float     // Capacidad tecnica Ej: 550 para panel, 4.8 para Bat
  brand         String?
  model         String?
  dimensions    String?
  surfaceM2     Float?
  efficiency    Float?
  price         Float?
  isActive      Boolean   @default(true)
}

model Parameter {
  id            Int       @id @default(autoincrement())
  key           String    @unique
  value         Float
  description   String?
}

model Lead {
  id            Int       @id @default(autoincrement())
  name          String
  email         String
  phone         String
  province      String
  userType      String
  monthlyKwh    Float?
  recommendedKw Float?
  createdAt     DateTime  @default(now())
}
