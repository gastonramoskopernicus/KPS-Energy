{
    "version": 2,
    "cleanUrls": true,
    "outputDirectory": ".",
    "rewrites": [
        {
            "source": "/admin",
            "destination": "/kps-admin/dist"
        },
        {
            "source": "/kps-admin/(.*)",
            "destination": "/kps-admin/dist/$1"
        }
    ]
}